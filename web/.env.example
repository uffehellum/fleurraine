# Fleurraine Frontend Environment Variables
# Copy this file to .env for local development

# API base URL (leave empty for same-origin requests in production)
VITE_API_URL=

# Venmo username for payment links
VITE_VENMO_USERNAME=LorraineSHellum

# Payment configuration
VITE_VENMO_HANDLE=your-venmo-username
VITE_DEFAULT_PRICE=10
