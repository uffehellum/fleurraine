# Fleurraine — required environment variables
# Copy this file to .env for local development.
# In production, set these via: fly secrets set KEY=value

# Comma-separated list of admin email addresses (e.g. lorraine@example.com)
ADMIN_EMAILS=

# fly.io PostgreSQL connection string
DATABASE_URL=

# Tigris object storage (S3-compatible)
TIGRIS_BUCKET=
TIGRIS_ACCESS_KEY_ID=
TIGRIS_SECRET_ACCESS_KEY=
TIGRIS_ENDPOINT_URL=

# Anthropic Claude Vision API key (photo category suggestions)
ANTHROPIC_API_KEY=

# Resend transactional email API key
RESEND_API_KEY=

# Lorraine's email address — receives order/subscription notifications
ADMIN_EMAIL=

# 32-byte random secret for session signing
SESSION_SECRET=

# Google OAuth 2.0 credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth credentials
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Comma-separated CORS origins for production (e.g. https://fleurraine.fly.dev)
ALLOWED_ORIGINS=

# HTTP port the Go server listens on (default: 8080)
PORT=8080

# Venmo username for payment links
VENMO_USERNAME=LorraineSHellum

# Default bouquet price in cents ($15.00)
DEFAULT_BOUQUET_PRICE_CENTS=1500

# Payment configuration
VITE_VENMO_HANDLE=your-venmo-username
VITE_DEFAULT_PRICE=10

# Stripe (server-side, not exposed to frontend)
# Use sk_test_... for sandbox/test mode, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER

# Sales tax — fixed rate for Camano Island point of sale
SALES_TAX_RATE=0.09
SALES_TAX_LABEL=Camano Island Sales Tax (9%)
