package ai

import (
	"bytes"
	"context"
	"encoding/json"
	"fmt"
	"io"
	"net/http"
	"os"
	"testing"
)

// TestListAvailableModels lists all models available with the current API key.
// This helps identify which models you have access to.
//
// Note: Anthropic doesn't have a public "list models" endpoint, so this test
// tries common model names to see which ones work.
//
// To run: go test -v ./internal/ai -run TestListAvailableModels
func TestListAvailableModels(t *testing.T) {
	// Load API key from .env file
	loadEnvFile(t)

	apiKey := os.Getenv("ANTHROPIC_API_KEY")
	if apiKey == "" {
		t.Skip("Skipping test: ANTHROPIC_API_KEY not set in .env or environment")
	}

	t.Log("Testing which Claude models are available with your API key...")
	t.Log("This may take a minute as we test each model...")

	// List of known Claude models to test
	modelsToTest := []string{
		// Claude 3.5 Sonnet (newest)
		"claude-3-5-sonnet-20241022",
		"claude-3-5-sonnet-20240620",

		// Claude 3 Opus (most capable)
		"claude-3-opus-20240229",

		// Claude 3 Sonnet (balanced)
		"claude-3-sonnet-20240229",

		// Claude 3 Haiku (fastest)
		"claude-3-haiku-20240307",

		// Claude 2.1 (older, may not have vision)
		"claude-2.1",
		"claude-2.0",

		// Claude Instant (legacy)
		"claude-instant-1.2",
	}

	// Create a minimal test image (1x1 pixel JPEG)
	minimalJPEG := []byte{
		0xFF, 0xD8, 0xFF, 0xE0, 0x00, 0x10, 0x4A, 0x46,
		0x49, 0x46, 0x00, 0x01, 0x01, 0x00, 0x00, 0x01,
		0x00, 0x01, 0x00, 0x00, 0xFF, 0xDB, 0x00, 0x43,
		0x00, 0x08, 0x06, 0x06, 0x07, 0x06, 0x05, 0x08,
		0x07, 0x07, 0x07, 0x09, 0x09, 0x08, 0x0A, 0x0C,
		0x14, 0x0D, 0x0C, 0x0B, 0x0B, 0x0C, 0x19, 0x12,
		0x13, 0x0F, 0x14, 0x1D, 0x1A, 0x1F, 0x1E, 0x1D,
		0x1A, 0x1C, 0x1C, 0x20, 0x24, 0x2E, 0x27, 0x20,
		0x22, 0x2C, 0x23, 0x1C, 0x1C, 0x28, 0x37, 0x29,
		0x2C, 0x30, 0x31, 0x34, 0x34, 0x34, 0x1F, 0x27,
		0x39, 0x3D, 0x38, 0x32, 0x3C, 0x2E, 0x33, 0x34,
		0x32, 0xFF, 0xC0, 0x00, 0x0B, 0x08, 0x00, 0x01,
		0x00, 0x01, 0x01, 0x01, 0x11, 0x00, 0xFF, 0xC4,
		0x00, 0x14, 0x00, 0x01, 0x00, 0x00, 0x00, 0x00,
		0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
		0x00, 0x00, 0x00, 0x03, 0xFF, 0xC4, 0x00, 0x14,
		0x10, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
		0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
		0x00, 0x00, 0xFF, 0xDA, 0x00, 0x08, 0x01, 0x01,
		0x00, 0x00, 0x3F, 0x00, 0x37, 0xFF, 0xD9,
	}

	availableModels := []string{}
	unavailableModels := []string{}

	for _, modelName := range modelsToTest {
		t.Logf("Testing model: %s", modelName)

		available, err := testModel(apiKey, modelName, minimalJPEG)
		if available {
			t.Logf("  ✅ AVAILABLE: %s", modelName)
			availableModels = append(availableModels, modelName)
		} else {
			t.Logf("  ❌ NOT AVAILABLE: %s (%v)", modelName, err)
			unavailableModels = append(unavailableModels, modelName)
		}
	}

	// Print summary
	t.Log("\n============================================================")
	t.Log("SUMMARY:")
	t.Log("============================================================")

	if len(availableModels) > 0 {
		t.Log("\n✅ AVAILABLE MODELS:")
		for _, model := range availableModels {
			t.Logf("  - %s", model)
		}
	} else {
		t.Log("\n❌ NO MODELS AVAILABLE")
		t.Log("Your API key doesn't have access to any Claude models.")
		t.Log("Please check:")
		t.Log("  1. API key is valid and not expired")
		t.Log("  2. API key has Claude API access enabled")
		t.Log("  3. You have sufficient credits/quota")
	}

	if len(unavailableModels) > 0 {
		t.Log("\n❌ UNAVAILABLE MODELS:")
		for _, model := range unavailableModels {
			t.Logf("  - %s", model)
		}
	}

	t.Log("\n============================================================")

	// Fail the test if no models are available
	if len(availableModels) == 0 {
		t.Fatal("No Claude models are available with your API key")
	}
}

// testModel tests if a specific model is available with the API key
// It tries multiple API versions to find one that works
func testModel(apiKey, modelName string, imageData []byte) (bool, error) {
	ctx := context.Background()

	// Try multiple API versions
	versions := []string{
		"2023-06-01",
		"2023-01-01",
		"2024-01-01",
		"2024-06-01",
	}

	for _, version := range versions {
		// Build a minimal request
		reqBody := map[string]interface{}{
			"model":      modelName,
			"max_tokens": 10,
			"messages": []map[string]interface{}{
				{
					"role": "user",
					"content": []map[string]interface{}{
						{
							"type": "text",
							"text": "Hi",
						},
					},
				},
			},
		}

		body, err := json.Marshal(reqBody)
		if err != nil {
			continue
		}

		httpReq, err := http.NewRequestWithContext(ctx, http.MethodPost, anthropicAPIURL, bytes.NewReader(body))
		if err != nil {
			continue
		}

		httpReq.Header.Set("Content-Type", "application/json")
		httpReq.Header.Set("x-api-key", apiKey)
		httpReq.Header.Set("anthropic-version", version)

		resp, err := http.DefaultClient.Do(httpReq)
		if err != nil {
			continue
		}

		_, err = io.ReadAll(resp.Body)
		resp.Body.Close()
		if err != nil {
			continue
		}

		// Check for 404 (model not found)
		if resp.StatusCode == 404 {
			continue // Try next version
		}

		// Check for success
		if resp.StatusCode == 200 {
			// Model is available with this version!
			return true, nil
		}

		// Other error - try next version
		continue
	}

	// None of the versions worked
	return false, fmt.Errorf("model not found with any API version")
}
